{
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(python -m pytest tests/ -v)",
      "Bash(python -m pytest --version)",
      "Bash(windows-notify:*)",
      "Bash(python -m pytest tests/ -v --tb=short)",
      "Bash(py -m pytest tests/ -v --tb=short)",
      "Bash(py -c \"import pytest; print(pytest.__version__)\")",
      "Bash(claude config --help)",
      "Bash(claude config list)",
      "Bash(powershell:*)",
      "Bash(claude config get hooks)",
      "Bash(git commit:*)",
      "Bash(dir:*)",
      "Bash(python -m pytest tests/ -v --tb=short --disable-warnings)",
      "Bash(rm:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(docs/LICENSE*)",
      "Write(.env*)",
      "Write(docs/LICENSE*)",
      "Write(**/secrets/**)",
      "Bash(curl:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm remove:*)",
      "Bash(psql:*)"
    ],
    "ask": []
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -File .claude/hooks/permission-request-notification.ps1"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"Add-Type -AssemblyName System.Windows.Forms; [System.Windows.Forms.MessageBox]::Show('Claude Codeがユーザーに質問しています', 'Claude Code - 質問', 'OK', 'Information')\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"Add-Type -AssemblyName System.Windows.Forms; [System.Windows.Forms.MessageBox]::Show('タスクが完了しました', 'Claude Code', 'OK', 'Information')\""
          }
        ]
      }
    ]
  }
}